    {
        "id": "11368780dd32680c",
        "type": "function",
        "z": "f6f2187d.f17ca8",
        "name": "Restore Payload",
        "func": "// 1. Retrieve the original data and guarantee it is a JSON object\nlet data = msg.originalData;\nif (typeof data === \"string\") {\n    data = JSON.parse(data);\n}\n\n// 2. Force the timestamp into a strict Date object\n// If the timestamp is somehow missing from Postman, this acts as a safety net and creates a new one using the current time.\nif (data.timestamp) {\n    data.timestamp = new Date(data.timestamp);\n} else {\n    data.timestamp = new Date(); \n}\n\n// 3. Assign the cleaned, formatted data back to the payload\nmsg.payload = data;\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 390,
